<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration>
  <session-factory>
  
    <!--  Database connection details -->
    <property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>
	<property name="connection.url">jdbc:mysql://localhost:3306/db_wipro</property>
	<property name="connection.username">root</property>
	<property name="connection.password">root</property>
	
    <!--  hibernate properties -->
    <property name="dialect">org.hibernate.dialect.MySQLDialect</property>
	<property name="show_sql">true</property>
	<property name="hbm2ddl.auto">update</property>
	
    <!-- entity class details / mapping configurations -->
    <mapping class="com.wipro.hibernate.entities.Employee"/>
    <mapping class="com.wipro.hibernate.entities.Address"/>
    <mapping class="com.wipro.hibernate.entities.Student"/>
    <mapping class="com.wipro.hibernate.entities.Product"/>
    
  </session-factory>
</hibernate-configuration>